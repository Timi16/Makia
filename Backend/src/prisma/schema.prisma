generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExportFormat {
  PDF
  EPUB
  MOBI
}

enum UserRole {
  USER
  ADMIN
}

enum ExportStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique
  passwordHash String
  name         String
  role         UserRole      @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  books        Book[]
  exportJobs   ExportJob[]
  assetUploads AssetUpload[]

  @@map("users")
}

model Book {
  id           String        @id @default(uuid()) @db.Uuid
  title        String
  description  String?
  coverUrl     String?
  genre        String?
  tags         String[]      @default([])
  userId       String        @db.Uuid
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapters     Chapter[]
  exportJobs   ExportJob[]
  assetUploads AssetUpload[]

  @@index([userId])
  @@map("books")
}

model Chapter {
  id        String           @id @default(uuid()) @db.Uuid
  bookId    String           @db.Uuid
  title     String
  content   String           @db.Text
  order     Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  book      Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  versions  ChapterVersion[]

  @@unique([bookId, order])
  @@index([bookId])
  @@map("chapters")
}

model ChapterVersion {
  id        String   @id @default(uuid()) @db.Uuid
  chapterId String   @db.Uuid
  content   String   @db.Text
  savedAt   DateTime @default(now())
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId, savedAt(sort: Desc)])
  @@map("chapter_versions")
}

model ExportJob {
  id           String       @id @default(uuid()) @db.Uuid
  bookId        String       @db.Uuid
  userId        String       @db.Uuid
  format        ExportFormat
  status        ExportStatus
  fileUrl       String?
  errorMessage  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  book          Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([userId])
  @@map("export_jobs")
}

model AssetUpload {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  bookId    String   @db.Uuid
  s3Key     String
  cdnUrl    String
  fileType  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([bookId])
  @@map("asset_uploads")
}
